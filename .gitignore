# Git 元数据
**/.git/

# 编译产物
**/build/
**/out/
**/dist/
**/bin/
**/obj/
**/.cache/

# 编译中间产物
*.o
*.obj
*.d
*.dep
*.lo
*.lai
*.su
*.gcno
*.gcda

# 库和可执行产物
*.a
*.la
*.so
*.so.*
*.dll
*.dylib
*.exe

# Python 等缓存
**/__pycache__/
*.pyc

# 系统与编辑器临时文件
**/.DS_Store
**/*.log
**/*.tmp
**/*.swp

# 敏感配置，公共仓库禁止上传
**/.env
**/.env.*
**/*.key
**/*.pem
**/*.p12
**/*.pfx
**/*token*
**/*secret*
